<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sr_background"
    tools:context=".MainActivity">

    <ScrollView
        android:id="@+id/home_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home"
                android:textColor="@color/sr_text_primary"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                style="@style/SafeRoute_SectionLabel"
                android:layout_marginTop="24dp"
                android:text="@string/realtime_alert" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_large"
                android:orientation="horizontal"
                android:padding="20dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_red"
                    android:contentDescription="@string/realtime_alert"
                    android:padding="12dp"
                    android:src="@drawable/ic_alert_triangle_24" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/disaster_alert_title"
                        android:textColor="@color/sr_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/disaster_alert_message"
                        android:textColor="@color/sr_text_secondary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/alert_source"
                        android:textColor="@color/sr_red"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    style="@style/SafeRoute_SectionLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/nearby_shelters" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all"
                    android:textColor="@color/sr_blue"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_large"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/home_shelter_one_name"
                            style="@style/SafeRoute_ItemTitle"
                            android:text="@string/shelter_one_name" />

                        <TextView
                            android:id="@+id/home_shelter_one_detail"
                            style="@style/SafeRoute_ItemSubtitle"
                            android:layout_marginTop="4dp"
                            android:text="@string/shelter_one_detail" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/home_shelter_one_distance"
                        style="@style/SafeRoute_DistanceText"
                        android:text="@string/shelter_one_distance" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/sr_separator" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/home_shelter_two_name"
                            style="@style/SafeRoute_ItemTitle"
                            android:text="@string/shelter_two_name" />

                        <TextView
                            android:id="@+id/home_shelter_two_detail"
                            style="@style/SafeRoute_ItemSubtitle"
                            android:layout_marginTop="4dp"
                            android:text="@string/shelter_two_detail" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/home_shelter_two_distance"
                        style="@style/SafeRoute_DistanceText"
                        android:text="@string/shelter_two_distance" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/SafeRoute_SectionLabel"
                android:layout_marginTop="24dp"
                android:text="@string/weather_summary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_large"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="20dp">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_icon_gray"
                    android:contentDescription="@string/weather_summary"
                    android:padding="12dp"
                    android:src="@drawable/ic_cloud_rain_24" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/SafeRoute_ItemTitle"
                        android:text="@string/heavy_rain_expected" />

                    <TextView
                        style="@style/SafeRoute_ItemSubtitle"
                        android:layout_marginTop="4dp"
                        android:text="@string/rainfall_detail" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_temperature"
                        android:textColor="@color/sr_text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wind_speed"
                        android:textColor="@color/sr_text_muted"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/map_screen"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/map_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_search_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/search_hint"
                    android:src="@drawable/ic_search_24" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="@string/search_hint"
                    android:textColor="@color/sr_text_muted"
                    android:textSize="16sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/filter_barrier_free_chip"
                        style="@style/SafeRoute_FilterChip"
                        android:drawableStart="@drawable/ic_barrier_free_24"
                        android:drawablePadding="6dp"
                        android:text="@string/barrier_free_filter" />

                    <TextView
                        android:id="@+id/filter_all_chip"
                        style="@style/SafeRoute_FilterChip"
                        android:background="@drawable/bg_chip_dark"
                        android:text="전체"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/filter_earthquake_chip"
                        style="@style/SafeRoute_FilterChip"
                        android:text="지진" />

                    <TextView
                        android:id="@+id/filter_rain_chip"
                        style="@style/SafeRoute_FilterChip"
                        android:text="민방위" />

                    <TextView
                        android:id="@+id/filter_snow_chip"
                        style="@style/SafeRoute_FilterChip"
                        android:text="산사태" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_my_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            android:contentDescription="@string/move_to_my_location"
            android:src="@drawable/ic_locate_fixed_24"
            android:visibility="visible"
            app:backgroundTint="@android:color/white"
            app:elevation="6dp"
            app:fabSize="mini"
            app:tint="@color/sr_blue" />

        <LinearLayout
            android:id="@+id/route_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="96dp"
            android:background="@drawable/bg_card_medium"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/route_info_title"
                style="@style/SafeRoute_ItemTitle"
                android:text="Shelter route" />

            <TextView
                android:id="@+id/route_info_detail"
                style="@style/SafeRoute_ItemSubtitle"
                android:layout_marginTop="6dp"
                android:text="Waiting for current location" />

            <TextView
                android:id="@+id/route_info_distance"
                style="@style/SafeRoute_DistanceText"
                android:layout_marginTop="10dp"
                android:text="-" />
        </LinearLayout>
    </FrameLayout>

    <ScrollView
        android:id="@+id/settings_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:textColor="@color/sr_text_primary"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                style="@style/SafeRoute_SectionLabel"
                android:layout_marginTop="24dp"
                android:text="@string/account" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_medium"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_gray"
                    android:contentDescription="@string/account"
                    android:padding="12dp"
                    android:src="@drawable/ic_user_24" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/SafeRoute_ItemTitle"
                        android:text="@string/login_required" />

                    <TextView
                        style="@style/SafeRoute_ItemSubtitle"
                        android:layout_marginTop="4dp"
                        android:text="@string/connect_account" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/SafeRoute_SectionLabel"
                android:layout_marginTop="24dp"
                android:text="@string/app_settings" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_medium"
                android:orientation="vertical">

                <LinearLayout
                    style="@style/SafeRoute_SettingsRow">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_dark"
                        android:contentDescription="@string/dark_mode"
                        android:padding="7dp"
                        android:src="@drawable/ic_moon_24" />

                    <TextView
                        style="@style/SafeRoute_ItemTitle"
                        android:layout_width="0dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/dark_mode" />

                    <Switch
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View style="@style/SafeRoute_Separator" />

                <LinearLayout
                    style="@style/SafeRoute_SettingsRow">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_red"
                        android:contentDescription="@string/disaster_notifications"
                        android:padding="7dp"
                        android:src="@drawable/ic_bell_24" />

                    <TextView
                        style="@style/SafeRoute_ItemTitle"
                        android:layout_width="0dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/disaster_notifications" />

                    <Switch
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View style="@style/SafeRoute_Separator" />

                <LinearLayout
                    style="@style/SafeRoute_SettingsRow">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_blue"
                        android:contentDescription="@string/privacy_security"
                        android:padding="7dp"
                        android:src="@drawable/ic_shield_24" />

                    <TextView
                        style="@style/SafeRoute_ItemTitle"
                        android:layout_width="0dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/privacy_security" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_card_medium"
                android:orientation="vertical">

                <LinearLayout
                    style="@style/SafeRoute_SettingsRow">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_muted"
                        android:contentDescription="@string/notices"
                        android:padding="7dp"
                        android:src="@drawable/ic_info_24" />

                    <TextView
                        style="@style/SafeRoute_ItemTitle"
                        android:layout_width="0dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/notices" />
                </LinearLayout>

                <View style="@style/SafeRoute_Separator" />

                <TextView
                    style="@style/SafeRoute_SettingsTextRow"
                    android:text="@string/app_version" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#E6FFFFFF"
        app:elevation="8dp"
        app:itemIconTint="@color/sr_bottom_nav_tint"
        app:itemTextColor="@color/sr_bottom_nav_tint"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
